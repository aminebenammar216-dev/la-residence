{% extends 'base.html.twig' %}

{% block title %}Connexion | La Résidence{% endblock %}

{% block body %}

<div class="login-page">

    <div class="overlay">

        <div class="login-card">

            <h1>🏡 La Résidence</h1>
            <p>Administration</p>

            {% if error %}
                <div class="alert">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post">

                <input
                    type="email"
                    name="email"
                    value="{{ last_username }}"
                    placeholder="Adresse e-mail"
                    required
                    autofocus
                >

                <input
                    type="password"
                    name="password"
                    placeholder="Mot de passe"
                    required
                >

                <input
                    type="hidden"
                    name="_csrf_token"
                    value="{{ csrf_token('authenticate') }}"
                >

                <button type="submit">
                    Se connecter
                </button>

            </form>

        </div>

    </div>

</div>

{% endblock %}